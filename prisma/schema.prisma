generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String                @id @db.Uuid
  email                String                @unique(map: "users_email_unique_active", where: raw("(deleted_at IS NULL)"))
  username             String?               @unique
  isAdmin              Boolean               @default(false) @map("is_admin")
  displayName          String?               @map("display_name")
  avatarUrl            String?               @map("avatar_url")
  statusText           String?               @map("status_text")
  statusEmoji          String?               @map("status_emoji")
  lastSeenAt           DateTime?             @map("last_seen_at")
  createdAt            DateTime              @default(now()) @map("created_at")
  password             String?
  deletedAt            DateTime?             @map("deleted_at")

  oauthAccounts        OAuthAccount[]
  uploadedAttachments  Attachment[]
  conversationMembers  ConversationMember[]
  conversationsCreated Conversation[]        @relation("ConversationCreator")
  mentions             Mention[]
  sentMessages         Message[]             @relation("MessageSender")
  notificationSettings NotificationSetting[]
  actorNotifications   Notification[]        @relation("NotificationActor")
  notifications        Notification[]        @relation("NotificationRecipient")
  pinnedMessages       PinnedMessage[]
  pushSubscriptions    PushSubscription[]
  reactions            Reaction[]
  refreshTokens        RefreshToken[]
  workspaceMemberships WorkspaceMember[]
  ownedWorkspaces      Workspace[]           @relation("WorkspaceOwner")
  createdWorkspaceInvites WorkspaceInvite[]         @relation("WorkspaceInviteCreator")
  workspaceInviteResponses WorkspaceInviteResponse[]

  @@map("users")
}

model OAuthAccount {
  id             String   @id @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  provider       String
  providerUserId String   @map("provider_user_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@map("oauth_accounts")
}

model Workspace {
  id                   String                @id @db.Uuid
  name                 String
  slug                 String                @unique
  iconUrl              String?               @map("icon_url")
  ownerId              String                @map("owner_id") @db.Uuid
  isDeleted            Boolean               @default(false) @map("is_deleted")
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime?             @map("updated_at")
  deletedAt            DateTime?             @map("deleted_at")
  bots                 Bot[]
  conversations        Conversation[]
  notificationSettings NotificationSetting[]
  notifications        Notification[]
  members              WorkspaceMember[]
  invites              WorkspaceInvite[]
  owner                User                  @relation("WorkspaceOwner", fields: [ownerId], references: [id])

  @@map("workspaces")
}

model WorkspaceMember {
  id          String        @id @db.Uuid
  workspaceId String        @map("workspace_id") @db.Uuid
  userId      String        @map("user_id") @db.Uuid
  role        WorkspaceRole @default(MEMBER)
  joinedAt    DateTime      @default(now()) @map("joined_at")
  leftAt      DateTime?     @map("left_at")
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

model WorkspaceInvite {
  id              String        @id @db.Uuid
  workspaceId     String        @map("workspace_id") @db.Uuid
  type            WorkspaceInviteType
  rawToken        String?       @unique @map("raw_token")
  invitedEmail    String?       @map("invited_email")
  role            WorkspaceRole @default(MEMBER)
  createdById     String        @map("created_by_id") @db.Uuid
  expiresAt       DateTime      @map("expires_at")
  revokedAt       DateTime?     @map("revoked_at")
  createdAt       DateTime      @default(now()) @map("created_at")

  workspace       Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdBy       User          @relation("WorkspaceInviteCreator", fields: [createdById], references: [id])
  responses       WorkspaceInviteResponse[]

  @@index([workspaceId])
  @@index([createdById])
  @@index([invitedEmail])
  @@index([expiresAt])
  @@map("workspace_invites")
}

model WorkspaceInviteResponse {
  id        String                        @id @db.Uuid
  inviteId  String                        @map("invite_id") @db.Uuid
  userId    String                        @map("user_id") @db.Uuid
  status    WorkspaceInviteResponseStatus
  createdAt DateTime                      @default(now()) @map("created_at")

  invite    WorkspaceInvite               @relation(fields: [inviteId], references: [id], onDelete: Cascade)
  user      User                          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([inviteId, userId])
  @@index([userId])
  @@map("workspace_invite_responses")
}

model Conversation {
  id             String               @id @db.Uuid
  workspaceId    String               @map("workspace_id") @db.Uuid
  type           ConversationType
  name           String?
  description    String?
  isPrivate      Boolean              @default(false) @map("is_private")
  isArchived     Boolean              @default(false) @map("is_archived")
  isDeleted      Boolean              @default(false) @map("is_deleted")
  createdBy      String               @map("created_by") @db.Uuid
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime?            @map("updated_at")
  deletedAt      DateTime?            @map("deleted_at")
  members        ConversationMember[]
  creator        User                 @relation("ConversationCreator", fields: [createdBy], references: [id])
  workspace      Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  messages       Message[]
  notifications  Notification[]
  pinnedMessages PinnedMessage[]

  @@index([workspaceId, type])
  @@map("conversations")
}

model ConversationMember {
  id             String           @id @db.Uuid
  conversationId String           @map("conversation_id") @db.Uuid
  userId         String           @map("user_id") @db.Uuid
  isMuted        Boolean          @default(false) @map("is_muted")
  role           ConversationRole @default(MEMBER)
  lastReadAt     DateTime?        @map("last_read_at")
  joinedAt       DateTime         @default(now()) @map("joined_at")
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@map("conversation_members")
}

model Message {
  id             String                   @id @db.Uuid
  conversationId String                   @map("conversation_id") @db.Uuid
  senderId       String?                  @map("sender_id") @db.Uuid
  botId          String?                  @map("bot_id") @db.Uuid
  parentId       String?                  @map("parent_id") @db.Uuid
  content        String?
  searchVector   Unsupported("tsvector")? @map("search_vector")
  isEdited       Boolean                  @default(false) @map("is_edited")
  isDeleted      Boolean                  @default(false) @map("is_deleted")
  editedAt       DateTime?                @map("edited_at")
  createdAt      DateTime                 @default(now()) @map("created_at")
  updatedAt      DateTime                 @updatedAt @map("updated_at")
  deletedAt      DateTime?                @map("deleted_at")
  attachments    Attachment[]
  mentions       Mention[]
  bot            Bot?                     @relation(fields: [botId], references: [id])
  conversation   Conversation             @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  parent         Message?                 @relation("thread", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies        Message[]                @relation("thread")
  sender         User?                    @relation("MessageSender", fields: [senderId], references: [id])
  notification   Notification[]
  pinnedIn       PinnedMessage?
  reactions      Reaction[]

  @@index([conversationId, createdAt(sort: Desc)])
  @@index([parentId])
  @@index([senderId])
  @@map("messages")
}

model Attachment {
  id         String   @id @db.Uuid
  messageId  String   @map("message_id") @db.Uuid
  uploaderId String   @map("uploader_id") @db.Uuid
  fileName   String   @map("file_name")
  fileType   String?  @map("file_type")
  fileSize   Int?     @map("file_size")
  storageUrl String   @map("storage_url")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")
  message    Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  uploader   User     @relation(fields: [uploaderId], references: [id])

  @@index([messageId])
  @@map("attachments")
}

model Reaction {
  id        String   @id @db.Uuid
  messageId String   @map("message_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  emoji     String
  createdAt DateTime @default(now()) @map("created_at")
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@map("reactions")
}

model Mention {
  id              String   @id @db.Uuid
  messageId       String   @map("message_id") @db.Uuid
  mentionedUserId String   @map("mentioned_user_id") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at")
  mentionedUser   User     @relation(fields: [mentionedUserId], references: [id], onDelete: Cascade)
  message         Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, mentionedUserId])
  @@map("mentions")
}

model PinnedMessage {
  id             String       @id @db.Uuid
  conversationId String       @map("conversation_id") @db.Uuid
  messageId      String       @unique @map("message_id") @db.Uuid
  pinnedBy       String       @map("pinned_by") @db.Uuid
  createdAt      DateTime     @default(now()) @map("created_at")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message        Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  pinnedByUser   User         @relation(fields: [pinnedBy], references: [id])

  @@map("pinned_messages")
}

model Notification {
  id             String           @id @db.Uuid
  userId         String           @map("user_id") @db.Uuid
  actorId        String?          @map("actor_id") @db.Uuid
  workspaceId    String           @map("workspace_id") @db.Uuid
  conversationId String?          @map("conversation_id") @db.Uuid
  messageId      String?          @map("message_id") @db.Uuid
  type           NotificationType
  payload        Json?
  isRead         Boolean          @default(false) @map("is_read")
  createdAt      DateTime         @default(now()) @map("created_at")
  actor          User?            @relation("NotificationActor", fields: [actorId], references: [id])
  conversation   Conversation?    @relation(fields: [conversationId], references: [id])
  message        Message?         @relation(fields: [messageId], references: [id])
  user           User             @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)
  workspace      Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt(sort: Desc)])
  @@map("notifications")
}

model NotificationSetting {
  id                   String    @id @db.Uuid
  userId               String    @map("user_id") @db.Uuid
  workspaceId          String    @map("workspace_id") @db.Uuid
  notifyMentions       Boolean   @default(true) @map("notify_mentions")
  notifyDirectMessages Boolean   @default(true) @map("notify_direct_messages")
  notifyAllMessages    Boolean   @default(false) @map("notify_all_messages")
  emailNotifications   Boolean   @default(true) @map("email_notifications")
  pushNotifications    Boolean   @default(true) @map("push_notifications")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace            Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@map("notification_settings")
}

model PushSubscription {
  id        String   @id @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  endpoint  String   @unique
  p256dhKey String   @map("p256dh_key")
  authKey   String   @map("auth_key")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("push_subscriptions")
}

model Bot {
  id             String    @id @db.Uuid
  workspaceId    String    @map("workspace_id") @db.Uuid
  name           String
  avatarUrl      String?   @map("avatar_url")
  webhookUrl     String?   @map("webhook_url")
  triggerKeyword String?   @map("trigger_keyword")
  systemPrompt   String?   @map("system_prompt")
  provider       String    @default("anthropic")
  model          String    @default("claude-sonnet-4-20250514")
  config         Json?
  isDeleted      Boolean   @default(false) @map("is_deleted")
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")
  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  messages       Message[]

  @@map("bots")
}

model RefreshToken {
  id         String    @id @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash")
  deviceInfo Json?     @map("device_info")
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@index([userId])
  @@map("refresh_tokens")
}

enum ConversationType {
  CHANNEL
  DM
  GROUP_DM
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
  GUEST
}

enum ConversationRole {
  ADMIN
  MEMBER
}

enum NotificationType {
  MENTION
  REACTION
  THREAD_REPLY
  DM
  BOT
}

enum WorkspaceInviteType {
  DIRECT
  LINK
}

enum WorkspaceInviteResponseStatus {
  ACCEPTED
  DENIED
}
