<div style="font-family: Arial, sans-serif; color: #222; line-height: 1.5;">
  <h2 style="margin-bottom: 12px;">Workspace invitation</h2>
  <p>{{inviterName}} invited you to join the {{workspaceName}} workspace on Weave.</p>
  <p>
    <a
      href="{{inviteUrl}}"
      style="display: inline-block; padding: 10px 16px; background: #2563eb; color: #fff; text-decoration: none; border-radius: 6px;"
    >Accept invitation</a>
  </p>
  <p style="font-size: 13px; color: #666;">If you were not expecting this invitation, you can ignore this email.</p>
  <p style="font-size: 12px; color: #888;">© {{year}} Weave</p>
</div>
